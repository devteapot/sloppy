{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "tests/**/*.ts",
      "apps/dashboard/**/*.ts",
      "*.json",
      "*.md",
      "!.claude/**",
      "!**/node_modules/**"
    ]
  }
}
